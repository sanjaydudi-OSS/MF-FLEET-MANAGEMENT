function renderSettings() {
  const s = state.settings;
  $('main').innerHTML = `
    <div class="sec-hdr"><h2>Settings</h2></div>
    <div class="grid g2" style="gap:20px;align-items:start">
      <div class="card">
        <div class="fw7 muted fs13" style="margin-bottom:16px">Contract Parameters</div>
        <div style="display:flex;flex-direction:column;gap:14px">
          <div class="field"><label class="lbl">Fixed Cost per Month (₹)</label><input id="s-fix" type="number" value="${s.fixedCostPerMonth||85000}"></div>
          <div class="field"><label class="lbl">Variable Rate per KM (₹)</label><input id="s-km" type="number" value="${s.variableRatePerKm||28}"></div>
          <div class="field"><label class="lbl">Transit Time Limit (hours)</label><input id="s-trans" type="number" value="${s.transitTimeLimitHrs||18}"></div>
          <div class="field"><label class="lbl">Free Maintenance Days per Vehicle/Month</label><input id="s-maint" type="number" value="${s.maintenanceFreeDaysPerMonth||2}"></div>
          <div class="field"><label class="lbl">Driver Food Allowance per Stationary Day (₹)</label><input id="s-food" type="number" value="${s.driverFoodAllowancePerDay||300}"></div>
          <button class="btn btn-primary" onclick="saveSettingsForm()">Save Settings</button>
          <div id="s-saved" style="display:none" class="alert alert-green">✓ Settings saved to Firebase!</div>
