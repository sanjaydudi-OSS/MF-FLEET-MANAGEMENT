      </div>
    </div>`, async ()=>{
    const load = $('t-load').value, unload = $('t-unload').value;
    let h = null;
    if (load && unload) h = ((new Date(unload)-new Date(load))/3600000).toFixed(2);
    const late = h && parseFloat(h) > (state.settings.transitTimeLimitHrs||18);
    if (late && !$('t-reason').value.trim()) return alert('Delay reason is mandatory when transit time exceeds '+state.settings.transitTimeLimitHrs+'hrs.');
    const stDays = parseFloat($('t-stat').value)||0;
    const foodExp = stDays * (state.settings.driverFoodAllowancePerDay||300);
    const data = {
      vehicleId:$('t-veh').value, driverId:$('t-drv').value,
      from:$('t-from').value.trim(), to:$('t-to').value.trim(),
      loadingDate:load, unloadingDate:unload,
      km:parseFloat($('t-km').value)||0, routeAdv:parseFloat($('t-adv').value)||0,
      stationaryDays:stDays, foodExp, transitHrs:h,
      delayReason:$('t-reason').value.trim(),
      status:$('t-status').value,
    };
    if (!data.vehicleId) return alert('Vehicle required');
    if (!data.from || !data.to) return alert('From and To required');
    if (id) data.id = id;
    await saveDoc('trips', data); closeModal(); renderTrips();
  }, true);
  // live transit check
  setTimeout(()=>{
    ['t-load','t-unload'].forEach(fid=>{
      const el=$(fid);
      if(el) el.addEventListener('change', updateTransitInfo);
    });
    updateTransitInfo();
  },50);
};

function updateTransitInfo() {
  const load=$('t-load')?.value, unload=$('t-unload')?.value;
  const info=$('t-transit-info'), wrap=$('t-delay-wrap');
  if (!load || !unload || !info) return;
  const h = ((new Date(unload)-new Date(load))/3600000).toFixed(2);
  const lim = state.settings.transitTimeLimitHrs||18;
  const late = parseFloat(h) > lim;
  info.innerHTML = `<div class="alert ${late?'alert-orange':'alert-green'}">Transit Time: <strong>${h} hours</strong> ${late?'⚠ EXCEEDS '+lim+'hr limit':'✓ Within limit'}</div>`;
  if(wrap) wrap.style.display = late ? 'block' : 'none';
}

window.deleteTrip = async function(id) {
  if (!confirm('Delete this trip?')) return;
  await deleteDoc('trips', id); renderTrips();
};

// ═══════════════════════════════════════════════════════════
// EXPENSES
// ═══════════════════════════════════════════════════════════
const EXP_TYPES = ['Diesel','Driver Salary','Driver Route Advance','Loading Charges','Unloading Charges','Fastag','Parking','Food (Driver)','AdBlue','Maintenance','Other'];

function renderExpenses() {
  const total = state.expenses.reduce((s,e)=>s+(parseFloat(e.amount)||0),0);
  const rows = [...state.expenses].sort((a,b)=>new Date(b.date)-new Date(a.date));
  $('main').innerHTML = `
    <div class="sec-hdr">
      <h2>Expenses</h2>
      <button class="btn btn-primary" onclick="editExpense(null)">${ICONS.plus} Add Expense</button>
    </div>
    <div class="flex fac gap12 mb12" style="margin-bottom:14px">
      <span class="muted fs13">Total Expenses:</span>
      <span class="mono fw8 red" style="font-size:16px">${fmtCur(total)}</span>
    </div>
    <div class="card">
      ${renderTable([
        {key:'date', label:'Date', render:r=>fmtDate(r.date)},
        {key:'vehicleId', label:'Vehicle', render:r=>escape(state.vehicles.find(v=>v.id===r.vehicleId)?.regNo||'General')},
        {key:'type', label:'Type', render:r=>badge(escape(r.type),'blue')},
        {key:'amount', label:'Amount', render:r=>`<span class="mono fw7 red">${fmtCur(r.amount)}</span>`},
        {key:'tripId', label:'Trip', render:r=>{const t=state.trips.find(x=>x.id===r.tripId);return t?escape(t.from+'→'+t.to):'–';}},
        {key:'note', label:'Note', render:r=>`<span class="muted">${escape(r.note||'–')}</span>`},
      ], rows, 'editExpense', 'deleteExpense')}
