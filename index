  storageBucket: "fleet-management-e8a56.firebasestorage.app",
  messagingSenderId: "856277919486",
  appId: "1:856277919486:web:dad4bda6e6672d5d2b27af"
};

firebase.initializeApp(firebaseConfig);
const auth = firebase.auth();
const db = firebase.database(); // Realtime Database

// ═══════════════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════════════
let uid = null;
let state = {
  settings: { fixedCostPerMonth: 85000, variableRatePerKm: 28, transitTimeLimitHrs: 18, maintenanceFreeDaysPerMonth: 2, driverFoodAllowancePerDay: 300 },
  vehicles: [], drivers: [], customers: [], trips: [], expenses: [], bills: []
};
let currentPage = 'dashboard';
let sidebarOpen = true;

// ═══════════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════════
const fmt = n => new Intl.NumberFormat('en-IN', {maximumFractionDigits:0}).format(n||0);
const fmtCur = n => '₹'+fmt(n);
const fmtDate = d => d ? new Date(d).toLocaleDateString('en-IN') : '–';
const fmtDT = d => d ? new Date(d).toLocaleString('en-IN',{dateStyle:'short',timeStyle:'short'}) : '–';
const uid4 = () => Math.random().toString(36).slice(2,10);
const $ = id => document.getElementById(id);
const q = sel => document.querySelector(sel);
const escape = s => String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');

function getBillingCycles(year, month) {
  const days = new Date(year, month, 0).getDate();
  if (days === 31) return [{start:1,end:15},{start:16,end:31}];
  if (days === 30) return [{start:1,end:15},{start:16,end:30}];
  if (days === 28) return [{start:1,end:15},{start:16,end:28}];
  return [{start:1,end:15},{start:16,end:days}]; // 29
}
function cycleDays(year, month, idx) {
  const c = getBillingCycles(year, month)[idx];
  return c.end - c.start + 1;
}
function cycleLabel(year, month, idx) {
  const c = getBillingCycles(year, month)[idx];
  const mn = new Date(year,month-1,1).toLocaleString('en-IN',{month:'short'});
  return `${c.start} ${mn} – ${c.end} ${mn} ${year}`;
}
function transitHrs(trip) {
  if (!trip.loadingDate || !trip.unloadingDate) return null;
  return ((new Date(trip.unloadingDate) - new Date(trip.loadingDate)) / 3600000).toFixed(2);
}
function calcFoodExp(trip) {
  const days = parseFloat(trip.stationaryDays) || 0;
  return days * (state.settings.driverFoodAllowancePerDay || 300);
}

// SVG icons
const ICONS = {
  dashboard: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>`,
  truck: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>`,
  trip: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6l9-3 9 3M3 18l9 3 9-3"/></svg>`,
  expense: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
  invoice: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
  people: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  settings: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93l-1.41 1.41M4.93 4.93l1.41 1.41M19.07 19.07l-1.41-1.41M4.93 19.07l1.41-1.41M20 12h2M2 12h2M12 20v2M12 2v2"/></svg>`,
  plus: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>`,
  edit: `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`,
  trash: `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6M9 6V4h6v2"/></svg>`,
  close: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`,
  check: `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>`,
  alert: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
  logout: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>`,
};

// ═══════════════════════════════════════════════════════════
// FIREBASE AUTH
// ═══════════════════════════════════════════════════════════
function dbg(msg, color) {
  const el = document.getElementById('login-debug');
  if (!el) return;
  el.style.display = 'block';
  const line = document.createElement('div');
  line.style.color = color || '#94a3b8';
  line.textContent = '› ' + msg;
  el.appendChild(line);
  el.scrollTop = el.scrollHeight;
}

function showLoginErr(msg) {
  const el = document.getElementById('login-err');
  if (!el) return;
  el.textContent = msg;
  el.style.display = 'block';
}
function hideLoginErr() {
  const el = document.getElementById('login-err');
  if (el) el.style.display = 'none';
}
function setLoginLoading(loading, label) {
  const btnSign = document.getElementById('btn-signin');
  const btnReg  = document.getElementById('btn-register');
  if (!btnSign) return;
  btnSign.disabled = loading;
  if (btnReg) btnReg.disabled = loading;
  btnSign.textContent = loading ? (label || 'Signing in…') : 'Sign In';
}

async function doLogin() {
  hideLoginErr();
  const email = document.getElementById('login-email').value.trim();
  const pass  = document.getElementById('login-pass').value;
  dbg('Sign In clicked | email: ' + (email || '(empty)'));
  if (!email || !pass) { showLoginErr('Please enter your email and password.'); return; }
  setLoginLoading(true, 'Signing in…');
  dbg('Calling Firebase Auth…');
  try {
    const result = await firebase.auth().signInWithEmailAndPassword(email, pass);
    dbg('Success! UID: ' + result.user.uid, '#10b981');
  } catch(e) {
    dbg('ERROR ' + e.code + ': ' + e.message, '#ef4444');
    setLoginLoading(false);
    const msgs = {
      'auth/user-not-found':          'No account with this email. Click "Create Account" first.',
      'auth/wrong-password':          'Wrong password. Please try again.',
      'auth/invalid-credential':      'Email or password is incorrect.',
      'auth/invalid-email':           'Invalid email address format.',
      'auth/too-many-requests':       'Too many attempts. Wait a moment then try again.',
      'auth/network-request-failed':  'Network error — check your internet connection.',
      'auth/operation-not-allowed':   'Email/Password sign-in is not enabled. Go to Firebase Console → Authentication → Sign-in method → Enable Email/Password.',
      'auth/configuration-not-found': 'Firebase Auth not set up. Enable Email/Password in Firebase Console → Authentication.',
    };
    showLoginErr(msgs[e.code] || ('Error (' + e.code + '): ' + e.message));
  }
}

async function doRegister() {
  hideLoginErr();
  const email = document.getElementById('login-email').value.trim();
  const pass  = document.getElementById('login-pass').value;
  dbg('Create Account clicked | email: ' + (email || '(empty)'));
  if (!email || !pass) { showLoginErr('Please enter your email and password.'); return; }
  if (pass.length < 6) { showLoginErr('Password must be at least 6 characters.'); return; }
  setLoginLoading(true, 'Creating account…');
  dbg('Calling Firebase createUser…');
  try {
    const result = await firebase.auth().createUserWithEmailAndPassword(email, pass);
    dbg('Account created! UID: ' + result.user.uid, '#10b981');
  } catch(e) {
    dbg('ERROR ' + e.code + ': ' + e.message, '#ef4444');
    setLoginLoading(false);
    const msgs = {
      'auth/email-already-in-use':    'Account already exists with this email. Use "Sign In".',
      'auth/weak-password':           'Password too weak. Use at least 6 characters.',
      'auth/invalid-email':           'Invalid email address format.',
      'auth/network-request-failed':  'Network error — check your internet connection.',
      'auth/operation-not-allowed':   'Email/Password sign-in is not enabled. Go to Firebase Console → Authentication → Sign-in method → Enable Email/Password.',
    };
    showLoginErr(msgs[e.code] || ('Error (' + e.code + '): ' + e.message));
  }
}

async function doLogout() {
  await firebase.auth().signOut();
}

