function ref(name) { return db.ref(`users/${uid}/${name}`); }

async function loadCollection(name) {
  const snap = await ref(name).once('value');
  const val = snap.val();
  if (!val) return [];
  return Object.entries(val).map(([id, data]) => ({ id, ...data }));
}

async function loadAllData() {
  $('main').innerHTML = '<div class="loading-overlay"><div class="spinner"></div><span>Loading your data…</span></div>';
  const [vehicles, drivers, customers, trips, expenses, bills, settingsSnap] = await Promise.all([
    loadCollection('vehicles'), loadCollection('drivers'), loadCollection('customers'),
    loadCollection('trips'), loadCollection('expenses'), loadCollection('bills'),
    db.ref(`users/${uid}/settings`).once('value')
  ]);
  state.vehicles = vehicles; state.drivers = drivers; state.customers = customers;
  state.trips = trips; state.expenses = expenses; state.bills = bills;
  const savedSettings = settingsSnap.val();
  if (savedSettings) state.settings = { ...state.settings, ...savedSettings };
}

async function saveDoc(name, data) {
  if (data.id) {
    const { id, ...rest } = data;
    await ref(name).child(id).set(rest);
    state[name] = state[name].map(x => x.id === id ? data : x);
  } else {
    const id = uid4();
    await ref(name).child(id).set(data);
    state[name].push({ id, ...data });
  }
}

async function deleteDoc(name, id) {
  await ref(name).child(id).remove();
  state[name] = state[name].filter(x => x.id !== id);
}

async function saveSettings() {
  await db.ref(`users/${uid}/settings`).set(state.settings);
}

