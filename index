// ═══════════════════════════════════════════════════════════
const firebaseConfig = {
  apiKey: "AIzaSyBakLpWeaWwjRLX6wmZ2mLA55JKBVuUgY0",
  authDomain: "fleet-management-e8a56.firebaseapp.com",
