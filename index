    </div>
    <p style="margin-top:16px;font-size:11px;color:var(--txt3)">Data saved securely in Firebase Realtime Database</p>
  </div>
</div>

<!-- MAIN APP (hidden until login) -->
<div id="app" style="display:none">
  <!-- SIDEBAR -->
  <aside id="sidebar">
    <div class="logo">
      <div class="logo-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
      </div>
      <div class="logo-text">
        <h1>FleetTrack</h1>
        <span>HMV Manager</span>
      </div>
    </div>
    <nav id="nav"></nav>
    <button class="sidebar-toggle" id="sidebar-toggle" onclick="toggleSidebar()">◀</button>
  </aside>

  <!-- MAIN CONTENT -->
  <main id="main"></main>
</div>

<!-- MODAL CONTAINER -->
<div id="modal-container"></div>

<script>
// ═══════════════════════════════════════════════════════════
