}

window.saveSettingsForm = async function() {
  state.settings = {
    fixedCostPerMonth: parseFloat($('s-fix').value)||85000,
    variableRatePerKm: parseFloat($('s-km').value)||28,
    transitTimeLimitHrs: parseFloat($('s-trans').value)||18,
    maintenanceFreeDaysPerMonth: parseFloat($('s-maint').value)||2,
    driverFoodAllowancePerDay: parseFloat($('s-food').value)||300,
  };
  await saveSettings();
  $('s-saved').style.display='flex';
  setTimeout(()=>{ const el=$('s-saved'); if(el) el.style.display='none'; },3000);
};

window.editCustomer = function(id) {
  const c = id ? state.customers.find(x=>x.id===id) : {};
  openModal(id?'Edit Customer':'Add Customer', `
    <div style="display:flex;flex-direction:column;gap:12px">
      <div class="field"><label class="lbl">Company Name</label><input id="c-name" value="${escape(c?.name||'')}"></div>
      <div class="field"><label class="lbl">GSTIN</label><input id="c-gstin" value="${escape(c?.gstin||'')}"></div>
      <div class="field"><label class="lbl">Contact No.</label><input id="c-contact" value="${escape(c?.contact||'')}"></div>
      <div class="field"><label class="lbl">Email</label><input id="c-email" type="email" value="${escape(c?.email||'')}"></div>
      <div class="field"><label class="lbl">Address</label><textarea id="c-addr" rows="2">${escape(c?.address||'')}</textarea></div>
    </div>`, async ()=>{
    const data = { name:$('c-name').value.trim(), gstin:$('c-gstin').value.trim(), contact:$('c-contact').value.trim(), email:$('c-email').value.trim(), address:$('c-addr').value.trim() };
    if (!data.name) return alert('Company name required');
    if (id) data.id = id;
    await saveDoc('customers', data); closeModal(); renderSettings();
  });
};

window.deleteCustomer = async function(id) {
  if (!confirm('Delete this customer?')) return;
  await deleteDoc('customers', id); renderSettings();
};

