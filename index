      </div>
      <div>
        <div class="card">
          <div class="sec-hdr">
            <span class="fw7 muted fs13">Customers</span>
            <button class="btn btn-outline btn-sm" onclick="editCustomer(null)">${ICONS.plus} Add</button>
          </div>
          ${renderTable([
            {key:'name', label:'Customer Name'},
            {key:'gstin', label:'GSTIN'},
            {key:'contact', label:'Contact'},
          ], state.customers, 'editCustomer', 'deleteCustomer')}
        </div>
      </div>
