// TABLE RENDERER
// ═══════════════════════════════════════════════════════════
function renderTable(cols, data, editFn, deleteFn, emptyMsg='No records yet.') {
  const thead = cols.map(c=>`<th>${c.label}</th>`).join('');
  const tbody = data.length === 0
    ? `<tr class="empty-row"><td colspan="${cols.length+1}">${emptyMsg}</td></tr>`
    : data.map(row=>{
        const cells = cols.map(c=>`<td>${c.render ? c.render(row) : escape(row[c.key]||'–')}</td>`).join('');
        const actions = `<td><div class="td-actions">
          ${editFn?`<button class="btn btn-ghost btn-sm" onclick="${editFn}('${row.id}')">${ICONS.edit}</button>`:''}
          ${deleteFn?`<button class="btn btn-ghost btn-sm" style="color:var(--red)" onclick="${deleteFn}('${row.id}')">${ICONS.trash}</button>`:''}
        </div></td>`;
        return `<tr>${cells}${actions}</tr>`;
      }).join('');
  return `<div class="tbl-wrap"><table><thead><tr>${thead}<th></th></tr></thead><tbody>${tbody}</tbody></table></div>`;
}

function badge(text, cls) { return `<span class="badge badge-${cls}">${text}</span>`; }

