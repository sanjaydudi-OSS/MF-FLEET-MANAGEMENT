        <div class="stat-lbl">Total Expenses</div>
        <div class="stat-val red">${fmtCur(totalExp)}</div>
      </div>
      <div class="card stat-card">
        <div class="stat-icon ${profit>=0?'green':'red'}">${ICONS.truck}</div>
        <div class="stat-lbl">Net ${profit>=0?'Profit':'Loss'}</div>
        <div class="stat-val ${profit>=0?'green':'red'}">${fmtCur(Math.abs(profit))}</div>
        <div class="stat-sub">${profit>=0?'▲ Profit':'▼ Loss'}</div>
      </div>
      <div class="card stat-card">
        <div class="stat-icon blue">${ICONS.truck}</div>
        <div class="stat-lbl">Active Vehicles</div>
        <div class="stat-val blue">${activeV}</div>
        <div class="stat-sub">of ${state.vehicles.length} total</div>
      </div>
    </div>
    <div class="grid g2">
      <div class="card">
        <div class="fw7 muted fs13" style="margin-bottom:14px">Expense Breakdown</div>
        ${expRows.length===0?'<div class="faint fs13">No expenses recorded yet.</div>':
          expRows.map(([type,amt])=>`
            <div class="flex fac gap8" style="margin-bottom:10px">
              <div class="fs13 muted" style="flex:1">${escape(type)}</div>
              <div class="mono fw7 fs13 red" style="min-width:90px;text-align:right">${fmtCur(amt)}</div>
              <div style="width:70px;height:6px;border-radius:3px;background:var(--bgi);overflow:hidden;flex-shrink:0">
                <div style="width:${((amt/totalExp)*100).toFixed(1)}%;height:100%;background:var(--red);border-radius:3px"></div>
              </div>
            </div>`).join('')}
      </div>
      <div class="card">
        <div class="fw7 muted fs13" style="margin-bottom:14px">Recent Trips</div>
        ${recent.length===0?'<div class="faint fs13">No trips recorded yet.</div>':
          recent.map(t=>{
            const v = state.vehicles.find(x=>x.id===t.vehicleId);
            const h = transitHrs(t);
            const late = h && parseFloat(h)>(state.settings.transitTimeLimitHrs||18);
            return `<div style="display:flex;justify-content:space-between;align-items:flex-start;padding:8px 0;border-bottom:1px solid rgba(42,58,85,.3)">
              <div>
                <div class="fw7 fs13">${escape(v?.regNo||'?')}</div>
                <div class="faint fs12">${escape(t.from||'')} → ${escape(t.to||'')}</div>
              </div>
              <div style="text-align:right">
                <div class="faint fs12">${fmtDate(t.loadingDate)}</div>
                ${h?`${badge(h+'h', late?'orange':'green')}`:''}
              </div>
            </div>`;
          }).join('')}
      </div>
    </div>
    ${violations.length>0?`
      <div class="alert alert-orange mt16">
        <span>${ICONS.alert}</span>
        <div>
          <div class="fw7" style="margin-bottom:6px">⚠ ${violations.length} trip(s) exceeded ${state.settings.transitTimeLimitHrs||18}hr transit limit</div>
          ${violations.map(t=>{
