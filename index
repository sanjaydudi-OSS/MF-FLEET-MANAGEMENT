  // recent trips
  const recent = [...state.trips].sort((a,b)=>new Date(b.loadingDate)-new Date(a.loadingDate)).slice(0,6);

  // violations
  const violations = state.trips.filter(t=>{
    const h = transitHrs(t);
    return h && parseFloat(h) > (state.settings.transitTimeLimitHrs||18);
  });

  $('main').innerHTML = `
    <h2 style="font-size:22px;font-weight:800;margin-bottom:20px">Fleet Dashboard</h2>
    <div class="grid g4" style="margin-bottom:20px">
      <div class="card stat-card">
